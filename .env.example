# ---------- Postgres ----------
POSTGRES_USER=taskflow
POSTGRES_PASSWORD=taskflow_dev_password
POSTGRES_DB=taskflow
POSTGRES_PORT=5432

# ---------- Backend API ----------
API_PORT=4000
DB_HOST=postgres
DB_PORT=5432
DB_USER=taskflow
DB_PASSWORD=taskflow_dev_password
DB_NAME=taskflow

# JWT — generate a long random string in production
JWT_SECRET=replace-me-with-a-long-random-string

NODE_ENV=production
LOG_LEVEL=info
CORS_ORIGIN=http://localhost:3000

# ---------- Frontend ----------
FRONTEND_PORT=3000
# Baked in at build time; browser uses this to hit the API
VITE_API_URL=http://localhost:4000
